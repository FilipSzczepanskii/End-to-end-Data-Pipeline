# Local DuckDB (default warehouse)
DUCKDB_PATH=./air_quality.duckdb

# Prefect
PREFECT_API_URL=http://127.0.0.1:4200/api

# OpenAQ key (free, https://explore.openaq.org/register). Optional.
OPENAQ_API_KEY=

# Local data layout
LOCAL_DATA_DIR=./data
LOG_LEVEL=INFO

# --- GCP variant (only needed if you switch dbt to the prod_bigquery target) ---
GCP_PROJECT_ID=
GCP_SA_KEY_PATH=
